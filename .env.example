# Smart PDF Scanner - Environment Variables Template
# Copy this file to .env and fill in your values

# LLM API Keys (optional - only needed for semantic enhancement)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Cloud OCR API Keys (optional - only needed if using cloud OCR)
GOOGLE_CLOUD_API_KEY=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Cloud Storage (optional - only needed for cloud API deployment)
S3_BUCKET_NAME=...
GCS_BUCKET_NAME=...

# Database (optional - only needed for cloud API deployment)
DATABASE_URL=postgresql://user:pass@localhost/dbname

# Redis (optional - only needed for cloud API caching)
REDIS_URL=redis://localhost:6379

# ─── Pipeline Configuration Overrides (SMART_PDF_ prefix) ───────────────────
# Any Config model field can be set via environment variable using the
# SMART_PDF_<FIELD_NAME> pattern (upper-case). These override YAML file values.
#
# General
# SMART_PDF_PROCESSING_MODE=balanced        # fast | balanced | high_fidelity
# SMART_PDF_MAX_FILE_SIZE_MB=150
#
# Stages (comma-separated list)
# SMART_PDF_ENABLED_STAGES=pdf_parser,layout_analyzer,ocr_processor,structure_recognizer,table_processor,image_processor,semantic_enhancer,markdown_generator
#
# OCR
# SMART_PDF_OCR_ENGINE=tesseract            # tesseract | easyocr
# SMART_PDF_OCR_LANGUAGES=eng              # comma-separated language codes
# SMART_PDF_OCR_CONFIDENCE_THRESHOLD=0.7
#
# Layout
# SMART_PDF_LAYOUT_ENGINE=heuristic        # heuristic | layoutparser
# SMART_PDF_LAYOUT_CONFIDENCE_THRESHOLD=0.7
#
# LLM
# SMART_PDF_LLM_PROVIDER=openai            # openai | anthropic | (unset to disable)
# SMART_PDF_LLM_MODEL=gpt-4-turbo
# SMART_PDF_LLM_MAX_TOKENS=4096
# SMART_PDF_LLM_TEMPERATURE=0.1
#
# Output
# SMART_PDF_INCLUDE_PAGE_NUMBERS=true
# SMART_PDF_EXPORT_TABLES_CSV=false
#
# Performance
# SMART_PDF_PARALLEL_PAGES=false
# SMART_PDF_MAX_WORKERS=4
# SMART_PDF_CACHE_ENABLED=true
#
# Logging
# SMART_PDF_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
# SMART_PDF_LOG_FORMAT=json                # json | text
