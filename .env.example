# Smart PDF Scanner - Environment Variables Template
# Copy this file to .env and fill in your values

# LLM API Keys (optional - only needed for semantic enhancement)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Cloud OCR API Keys (optional - only needed if using cloud OCR)
GOOGLE_CLOUD_API_KEY=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Cloud Storage (optional - only needed for cloud API deployment)
S3_BUCKET_NAME=...
GCS_BUCKET_NAME=...

# Database (optional - only needed for cloud API deployment)
DATABASE_URL=postgresql://user:pass@localhost/dbname

# Redis (optional - only needed for cloud API caching)
REDIS_URL=redis://localhost:6379

# Configuration Overrides
# SMART_PDF_PROCESSING_MODE=balanced
# SMART_PDF_MAX_FILE_SIZE_MB=150
# SMART_PDF_LOG_LEVEL=INFO
